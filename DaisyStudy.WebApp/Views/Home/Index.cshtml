@using DaisyStudy.ViewModels.Common;
@model PagedResult<DaisyStudy.ViewModels.Catalog.Classes.ClassViewModel>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration;

@{
    ViewData["Title"] = "Trang chủ";
}

@section Scripts{
<script>
    setTimeout(function () {
        $('#msgAlert').fadeOut('slow');
    }, 2000);
</script>
}

<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Trang chủ</h1>
    <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm"><i
            class="fas fa-download fa-sm text-white-50"></i> Generate Report</a>
</div>

<div class="row">

    @if (Model != null)
    {
        @foreach (var item in Model.Items)
        {
            <div class="col-xl-6 col-lg-6">
                <!-- Dropdown Card Example -->
        <div class="card shadow mb-4">
                    <!-- Card Header - Dropdown -->
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <a href="@Url.Action("OverView", "Class", new {ClassID = item.ID })">
                            <h6 class="m-0 font-weight-bold text-primary">@item.ClassName - tạo bởi @item.Teacher</h6>
                        </a>
                        <div class="dropdown no-arrow">
                            <a class="dropdown-toggle" href="#" role="button" id="dropdownMenuLink" data-toggle="dropdown"
                        aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-ellipsis-v fa-sm fa-fw text-gray-400"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--fade-in"
                        aria-labelledby="dropdownMenuLink">
                                <div class="dropdown-header">Dropdown Header:</div>
                                <a class="dropdown-item" href="#">Action</a>
                                <a class="dropdown-item" href="#">Another action</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Something else here</a>
                            </div>
                        </div>
                    </div>
                    <div class="text-center">
                        <a href="@Url.Action("OverView", "Class", new {ClassID = item.ID })">
                            <img class="img-fluid img-card" src="@(Configuration["BaseAddress"] + @item.Image)" alt="@item.Image">
                        </a>
                    </div>
                    <!-- Card Body -->
            <div class="card-body">
                        <div class="row">
                            <div class="col">
                                <i class="fa-solid fa-bookmark me-2"></i> Chủ đề: @Html.DisplayFor(modelItem => item.Topic)
                                <br>
                                <i class="fa-regular fa-calendar-plus me-2"></i> Ngày tạo: @Html.DisplayFor(modelItem =>
                        item.DateCreated)
                                @if (item.Tuition == 0)
                                {
                                    <div>
                                        <i class="fa-solid fa-sack-dollar me-2"></i> Học phí: miễn phí
                                    </div>
                                }
                                else
                                {
                                    <div>
                                        <i class="fa-solid fa-sack-dollar me-2"></i> Học phí: @Html.DisplayFor(modelItem => item.Tuition)
                                    </div>
                                }
                                <i class="fa-solid fa-user-group me-2"></i> Học viên: @Html.DisplayFor(modelItem =>
                        item.StudentNumber)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }



</div>
