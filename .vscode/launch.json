            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/DaisyStudy.AdminApp/bin/Debug/net6.0/DaisyStudy.AdminApp.dll",
            "args": [],
